# AssetsGrator Smart Contracts — Environment Variables
# Copy this file to .env and fill in the values
# Never commit .env to git — it is in .gitignore

# ── Deployer Wallet ──────────────────────────────────────────────────────────
# Private key of the wallet you will deploy from (WITHOUT 0x prefix)
# Must have Sepolia ETH — get free ETH from https://sepoliafaucet.com
PRIVATE_KEY=

# ── RPC URLs ─────────────────────────────────────────────────────────────────
# Ethereum Sepolia — primary network (Fhenix CoFHE co-processor runs here)
# Get a free RPC at https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/824923bc363d475fad860c40c30781ac

# ── Contract Verification ─────────────────────────────────────────────────────
# Get a free Etherscan API key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Gas Reporting (optional) ──────────────────────────────────────────────────
REPORT_GAS=false
COINMARKETCAP_API_KEY=
