# PropAsset Smart Contracts — Environment Variables
# Copy this file to .env and fill in the values

# ── Deployer Wallet ──────────────────────────────────────────────────────────
# Private key of the deployer wallet (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# ── RPC URLs ─────────────────────────────────────────────────────────────────
# Polygon Amoy Testnet (Alchemy)
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/peDij9jekttvNoG7q6C0S

# Legacy Mumbai (deprecated)
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Polygon Mainnet
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com

# ── Contract Verification ─────────────────────────────────────────────────────
# Get your free API key at https://amoy.polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ── USDC (Mock on Amoy, real on Mainnet) ─────────────────────────────────────
# On Amoy testnet we deploy MockUSDC — address filled in automatically by deploy script
# Polygon Mainnet USDC (bridged): 0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
USDC_ADDRESS_MAINNET=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359

# ── Gas Reporting (optional) ──────────────────────────────────────────────────
REPORT_GAS=false
COINMARKETCAP_API_KEY=
